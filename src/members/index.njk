---
layout: layouts/base.njk
title: Members Area
description: "Manchester LMC subscriber area — access agenda papers, meeting minutes, the open forum, and exclusive member resources."
mainClass: page-members
showContactStrip: false
showDisclaimer: true
---

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
          <li><a href="/">Home</a></li>
          <li aria-current="page">Members Area</li>
        </ol>
      </nav>
      <h1>Members Area</h1>
      <p>Exclusive resources for Manchester LMC members — agenda papers, meeting minutes, the open forum, and subscriber-only guidance.</p>
    </div>
  </section>

  <!-- Login / Register -->
  <section class="section" id="login">
    <div class="container">
      <div class="members-layout">

        <!-- Auth panel -->
        <div>
          <div class="auth-tabs" role="tablist" aria-label="Login or Register">
            <button class="auth-tab-btn active" role="tab" aria-selected="true" aria-controls="panel-login" id="tab-login" data-auth-tab="login">Log In</button>
            <button class="auth-tab-btn" role="tab" aria-selected="false" aria-controls="panel-register" id="tab-register" data-auth-tab="register">Register</button>
          </div>

          <!-- Login panel -->
          <div class="auth-panel active" id="panel-login" role="tabpanel" aria-labelledby="tab-login">
            <h2 style="margin-top: 0;">Welcome back</h2>
            <p style="color: var(--colour-muted); margin-bottom: 2rem;">Log in with your registered email address and password to access subscriber content.</p>

            <form id="login-form" novalidate>
              <div class="form-group">
                <label class="form-label" for="login-email">Email address</label>
                <input class="form-input" type="email" id="login-email" name="email" autocomplete="email" required placeholder="your@email.com">
              </div>
              <div class="form-group">
                <label class="form-label" for="login-password">Password</label>
                <input class="form-input" type="password" id="login-password" name="password" autocomplete="current-password" required placeholder="••••••••">
              </div>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.5rem;">
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.9rem;">
                  <input type="checkbox" name="remember"> Remember me
                </label>
                <a href="#" style="font-size: 0.9rem; color: var(--colour-secondary);">Forgotten your password?</a>
              </div>
              <button type="submit" class="btn btn--primary" style="width: 100%;">Log In</button>
            </form>

            <div id="login-error" class="alert alert--warning" style="display: none; margin-top: 1.5rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <div>Incorrect email or password. Please try again, or <a href="#">reset your password</a>.</div>
            </div>

            <p style="margin-top: 2rem; text-align: center; font-size: 0.9rem; color: var(--colour-muted);">
              Not yet registered? <a href="#register" data-auth-switch="register">Create an account</a>
            </p>
          </div>

          <!-- Register panel -->
          <div class="auth-panel" id="panel-register" role="tabpanel" aria-labelledby="tab-register">
            <h2 style="margin-top: 0;" id="register">Register for access</h2>
            <p style="color: var(--colour-muted);">Practice staff and GPs within a contracted practice are registered automatically. The form below is for <strong>locum and portfolio GPs</strong> who are not attached to a member practice.</p>

            <div class="alert alert--info" style="margin-bottom: 2rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <div>Locum and portfolio GP subscriptions are <strong>£100 per year</strong>. You will receive a payment link by email after submitting this form.</div>
            </div>

            <form id="register-form" novalidate>
              <div class="grid-2" style="gap: 1rem;">
                <div class="form-group">
                  <label class="form-label" for="reg-firstname">First name <span aria-hidden="true">*</span></label>
                  <input class="form-input" type="text" id="reg-firstname" name="firstname" autocomplete="given-name" required>
                </div>
                <div class="form-group">
                  <label class="form-label" for="reg-lastname">Last name <span aria-hidden="true">*</span></label>
                  <input class="form-input" type="text" id="reg-lastname" name="lastname" autocomplete="family-name" required>
                </div>
              </div>
              <div class="form-group">
                <label class="form-label" for="reg-email">Email address <span aria-hidden="true">*</span></label>
                <input class="form-input" type="email" id="reg-email" name="email" autocomplete="email" required placeholder="your@email.com">
              </div>
              <div class="form-group">
                <label class="form-label" for="reg-gmc">GMC number <span aria-hidden="true">*</span></label>
                <input class="form-input" type="text" id="reg-gmc" name="gmc" placeholder="e.g. 1234567" required pattern="[0-9]{7}">
                <span class="form-hint">7-digit GMC registration number</span>
              </div>
              <div class="form-group">
                <label class="form-label" for="reg-role">Role <span aria-hidden="true">*</span></label>
                <select class="form-input" id="reg-role" name="role" required>
                  <option value="">Please select…</option>
                  <option>Locum GP</option>
                  <option>Portfolio GP</option>
                  <option>GP Registrar (not at member practice)</option>
                  <option>Retired GP</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label" for="reg-password">Choose a password <span aria-hidden="true">*</span></label>
                <input class="form-input" type="password" id="reg-password" name="password" autocomplete="new-password" required minlength="8" placeholder="Minimum 8 characters">
              </div>
              <div class="form-group">
                <label class="form-label" for="reg-password2">Confirm password <span aria-hidden="true">*</span></label>
                <input class="form-input" type="password" id="reg-password2" name="password2" autocomplete="new-password" required minlength="8" placeholder="Re-enter password">
              </div>
              <div class="form-group">
                <label style="display: flex; gap: 0.75rem; align-items: flex-start; cursor: pointer;">
                  <input type="checkbox" name="terms" required style="margin-top: 3px; flex-shrink: 0;">
                  <span style="font-size: 0.9rem;">I agree to the <a href="#">Terms of Use</a> and <a href="#">Privacy Policy</a>. I understand my subscription will be £100/year and will be activated on receipt of payment.</span>
                </label>
              </div>
              <button type="submit" class="btn btn--accent" style="width: 100%;">Register &amp; Proceed to Payment</button>
            </form>

            <p style="margin-top: 2rem; text-align: center; font-size: 0.9rem; color: var(--colour-muted);">
              Already have an account? <a href="#login" data-auth-switch="login">Log in</a>
            </p>

            <p style="margin-top: 1rem; text-align: center; font-size: 0.85rem; color: var(--colour-muted);">
              Practice staff at member practices should contact <a href="mailto:info@manchesterlmc.co.uk">info@manchesterlmc.co.uk</a> for access.
            </p>
          </div>

          <!-- Authenticated state (shown when logged in via JS) -->
          <div id="member-content" style="display: none;">
            <div class="alert alert--success" style="margin-bottom: 2rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              <div>You are logged in. Welcome to the Manchester LMC members area.</div>
            </div>

            <h2 style="margin-top: 0;">Your Resources</h2>

            <h3>Upcoming Meeting Agenda Papers</h3>
            <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem;">
              <div class="member-resource-item">
                <div class="member-resource-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                </div>
                <div style="flex: 1;">
                  <a href="#">LMC Full Meeting — Agenda &amp; Papers, March 2026</a>
                  <div class="meta">PDF · Distributed 5 March 2026</div>
                </div>
                <span class="badge badge--accent">New</span>
              </div>
              <div class="member-resource-item">
                <div class="member-resource-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                </div>
                <div style="flex: 1;">
                  <a href="#">LMC Full Meeting — Agenda &amp; Papers, January 2026</a>
                  <div class="meta">PDF · Distributed 8 January 2026</div>
                </div>
              </div>
              <div class="member-resource-item">
                <div class="member-resource-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                </div>
                <div style="flex: 1;">
                  <a href="#">AGM 2025 — Agenda, Accounts &amp; Minutes</a>
                  <div class="meta">PDF · May 2025</div>
                </div>
              </div>
            </div>

            <h3>Meeting Minutes Archive</h3>
            <div class="accordion" style="margin-bottom: 2rem;">
              <div class="accordion-item">
                <button class="accordion-btn" aria-expanded="true">
                  2025 Minutes
                  <svg class="accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <div class="accordion-panel" style="display: block;">
                  <div style="display: flex; flex-direction: column; gap: 0.5rem; padding: 1rem 0;">
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">Full Meeting — November 2025 (PDF)</a>
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">Full Meeting — September 2025 (PDF)</a>
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">Full Meeting — July 2025 (PDF)</a>
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">Full Meeting — May 2025 (PDF)</a>
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">Full Meeting — March 2025 (PDF)</a>
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">Full Meeting — January 2025 (PDF)</a>
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">AGM — May 2025 (PDF)</a>
                  </div>
                </div>
              </div>
              <div class="accordion-item">
                <button class="accordion-btn" aria-expanded="false">
                  2024 Minutes
                  <svg class="accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <div class="accordion-panel" hidden>
                  <div style="display: flex; flex-direction: column; gap: 0.5rem; padding: 1rem 0;">
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">Full Meeting — November 2024 (PDF)</a>
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">Full Meeting — September 2024 (PDF)</a>
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">Full Meeting — July 2024 (PDF)</a>
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">Full Meeting — May 2024 (PDF)</a>
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">Full Meeting — March 2024 (PDF)</a>
                    <a href="#" style="color: var(--colour-secondary); font-size: 0.9rem;">AGM — May 2024 (PDF)</a>
                  </div>
                </div>
              </div>
            </div>

            <h3>Open Forum</h3>
            <p style="color: var(--colour-muted); margin-bottom: 1rem;">The Manchester LMC Open Forum is a private online space for members to raise issues, share experiences, and connect with colleagues across the city.</p>
            <a href="#" class="btn btn--primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="vertical-align: middle; margin-right: 0.5rem;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Go to Open Forum
            </a>

            <hr style="margin: 2.5rem 0; border: none; border-top: 1px solid var(--colour-border);">

            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
              <div>
                <p style="margin: 0; font-size: 0.9rem; color: var(--colour-muted);">Logged in as <strong>member@example.com</strong></p>
              </div>
              <button id="logout-btn" class="btn btn--sm btn--outline">Log Out</button>
            </div>
          </div>

        </div>

        <!-- Sidebar -->
        <aside>
          <div class="card" style="padding: 1.5rem; margin-bottom: 1.5rem;">
            <h3 style="margin-top: 0; font-size: 1.1rem;">Member Benefits</h3>
            <div>
              <div class="benefit-row">
                <div class="benefit-check">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <p style="margin: 0; font-size: 0.9rem;">Agenda papers &amp; meeting minutes</p>
              </div>
              <div class="benefit-row">
                <div class="benefit-check">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <p style="margin: 0; font-size: 0.9rem;">Subscriber-only newsletters &amp; briefings</p>
              </div>
              <div class="benefit-row">
                <div class="benefit-check">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <p style="margin: 0; font-size: 0.9rem;">Open forum access</p>
              </div>
              <div class="benefit-row">
                <div class="benefit-check">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <p style="margin: 0; font-size: 0.9rem;">Confidential advisory service</p>
              </div>
              <div class="benefit-row">
                <div class="benefit-check">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <p style="margin: 0; font-size: 0.9rem;">Vacancy posting for practices</p>
              </div>
              <div class="benefit-row">
                <div class="benefit-check">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <p style="margin: 0; font-size: 0.9rem;">Representation at LMC conferences</p>
              </div>
            </div>
          </div>

          <div class="card" style="padding: 1.5rem; margin-bottom: 1.5rem; border-left: 4px solid var(--colour-accent);">
            <h3 style="margin-top: 0; font-size: 1rem;">Locum &amp; Portfolio GPs</h3>
            <p style="font-size: 0.9rem; color: var(--colour-muted); margin-bottom: 1rem;">Not attached to a member practice? Subscribe for just £100/year for full member access.</p>
            <a href="#register" class="btn btn--accent btn--sm" style="width: 100%; text-align: center;" data-auth-switch="register">Register Now</a>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="margin-top: 0; font-size: 1rem;">Need Help?</h3>
            <p style="font-size: 0.9rem; color: var(--colour-muted); margin-bottom: 1rem;">Problems accessing your account or questions about membership?</p>
            <p style="font-size: 0.9rem; margin: 0;">
              <a href="mailto:info@manchesterlmc.co.uk">info@manchesterlmc.co.uk</a><br>
              <a href="tel:01613015050">0161 301 5050</a><br>
              <span style="color: var(--colour-muted);">Mon–Fri, 9am–5pm</span>
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- What's in the members area (teaser for non-logged-in users) -->
  <section class="section" style="background: var(--colour-neutral);" id="what-is-in-members-area">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: 0.5rem;">What's in the Members Area</h2>
      <p class="text-center" style="color: var(--colour-muted); max-width: 600px; margin: 0 auto 3rem;">Everything you need to stay informed and connected as a Manchester GP — in one secure place.</p>

      <div class="grid-3" style="gap: 1.5rem;">
        <div class="card" style="padding: 1.75rem; text-align: center;">
          <div style="width: 56px; height: 56px; background: var(--colour-primary); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3 style="margin: 0 0 0.5rem;">Agenda &amp; Minutes</h3>
          <p style="color: var(--colour-muted); font-size: 0.9rem; margin: 0;">Download agenda papers before meetings and read minutes afterwards. Stay informed on decisions that affect your practice.</p>
        </div>
        <div class="card" style="padding: 1.75rem; text-align: center;">
          <div style="width: 56px; height: 56px; background: var(--colour-primary); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 style="margin: 0 0 0.5rem;">Open Forum</h3>
          <p style="color: var(--colour-muted); font-size: 0.9rem; margin: 0;">A private, members-only discussion space. Raise issues, share experiences, and connect with GPs from across Manchester.</p>
        </div>
        <div class="card" style="padding: 1.75rem; text-align: center;">
          <div style="width: 56px; height: 56px; background: var(--colour-primary); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <h3 style="margin: 0 0 0.5rem;">Subscriber Briefings</h3>
          <p style="color: var(--colour-muted); font-size: 0.9rem; margin: 0;">In-depth member briefings on contracts, policy changes, and local GP news — separate from the public newsletter.</p>
        </div>
        <div class="card" style="padding: 1.75rem; text-align: center;">
          <div style="width: 56px; height: 56px; background: var(--colour-primary); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 style="margin: 0 0 0.5rem;">Confidential Advice</h3>
          <p style="color: var(--colour-muted); font-size: 0.9rem; margin: 0;">Access to confidential advisory support from our Managing Director — for GMC, CQC, partnership, or contractual concerns.</p>
        </div>
        <div class="card" style="padding: 1.75rem; text-align: center;">
          <div style="width: 56px; height: 56px; background: var(--colour-primary); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <h3 style="margin: 0 0 0.5rem;">Post Vacancies</h3>
          <p style="color: var(--colour-muted); font-size: 0.9rem; margin: 0;">Member practices can post GP and practice staff vacancies directly to the Manchester LMC job board — free of charge.</p>
        </div>
        <div class="card" style="padding: 1.75rem; text-align: center;">
          <div style="width: 56px; height: 56px; background: var(--colour-primary); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 style="margin: 0 0 0.5rem;">Conference Representation</h3>
          <p style="color: var(--colour-muted); font-size: 0.9rem; margin: 0;">Member GPs are eligible to stand as LMC conference representatives, taking Manchester's voice to national BMA/GPC meetings.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 760px;">
      <h2>Membership FAQs</h2>
      <div class="accordion">

        <div class="accordion-item">
          <button class="accordion-btn" aria-expanded="false">
            My practice holds an NHS contract — do I need to register?
            <svg class="accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="accordion-panel" hidden>
            <p>GP partners, salaried GPs, and practice staff at NHS-contracted Manchester practices are covered by the practice levy and do not need to pay separately. Contact us at <a href="mailto:info@manchesterlmc.co.uk">info@manchesterlmc.co.uk</a> to set up your account and we will verify your practice membership.</p>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-btn" aria-expanded="false">
            I've forgotten my password — how do I reset it?
            <svg class="accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="accordion-panel" hidden>
