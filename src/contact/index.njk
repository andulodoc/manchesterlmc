---

  <!-- ── Page Hero ──────────────────────────────────────────── -->
  <section class="page-hero" aria-label="Page header">
    <div class="container">
      <div class="page-hero-content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb-sep" aria-hidden="true">›</span>
          <span aria-current="page">Contact</span>
        </nav>
        <h1>Contact Us</h1>
        <p>We're here to help. Reach our team by phone, email, or using the form below.</p>
      </div>
    </div>
  </section>

  <!-- ── Contact Info + Map ──────────────────────────────────── -->
  <section class="section" aria-labelledby="contact-details-heading">
    <div class="container">
      <div class="grid-2" style="align-items: start;">

        <!-- Left: contact details -->
        <div>
          <h2 id="contact-details-heading" style="margin-bottom: var(--space-6);">Get in Touch</h2>

          <!-- Address -->
          <div style="display: flex; gap: var(--space-4); margin-bottom: var(--space-6);">
            <div style="flex-shrink: 0; width: 40px; height: 40px; background-color: var(--colour-neutral); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: var(--colour-secondary);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p style="font-weight: 600; color: var(--colour-primary); margin-bottom: var(--space-1);">Our Office</p>
              <address style="font-style: normal; color: var(--colour-muted); line-height: 1.7;">
                Oak House<br>
                47 Graham Street<br>
                Beswick<br>
                Manchester, M11 3BB
              </address>
            </div>
          </div>

          <!-- Telephone -->
          <div style="display: flex; gap: var(--space-4); margin-bottom: var(--space-6);">
            <div style="flex-shrink: 0; width: 40px; height: 40px; background-color: var(--colour-neutral); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: var(--colour-secondary);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18H6.6a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.51 8.69a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 15.92z"/>
              </svg>
            </div>
            <div>
              <p style="font-weight: 600; color: var(--colour-primary); margin-bottom: var(--space-1);">Telephone</p>
              <p style="margin-bottom: var(--space-1);">
                <a href="tel:01612230032" style="color: var(--colour-muted);">0161 223 0032</a>
              </p>
              <p>
                <a href="tel:01612220088" style="color: var(--colour-muted);">0161 222 0088</a>
              </p>
            </div>
          </div>

          <!-- Email -->
          <div style="display: flex; gap: var(--space-4); margin-bottom: var(--space-6);">
            <div style="flex-shrink: 0; width: 40px; height: 40px; background-color: var(--colour-neutral); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: var(--colour-secondary);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p style="font-weight: 600; color: var(--colour-primary); margin-bottom: var(--space-1);">Email</p>
              <a href="mailto:info@manchesterlmc.co.uk" style="color: var(--colour-muted);">info@manchesterlmc.co.uk</a>
            </div>
          </div>

          <!-- Office hours -->
          <div style="display: flex; gap: var(--space-4); margin-bottom: var(--space-8);">
            <div style="flex-shrink: 0; width: 40px; height: 40px; background-color: var(--colour-neutral); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: var(--colour-secondary);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <p style="font-weight: 600; color: var(--colour-primary); margin-bottom: var(--space-1);">Office Hours</p>
              <p style="color: var(--colour-muted);">Monday – Friday: 09:00 – 17:00</p>
              <p style="color: var(--colour-muted); font-size: 0.875rem; margin-top: var(--space-1);">Closed on bank holidays</p>
            </div>
          </div>

          <!-- Key contacts -->
          <div style="background-color: var(--colour-neutral); border-radius: var(--radius-lg); padding: var(--space-6);">
            <h3 style="font-size: 1rem; margin-bottom: var(--space-5); color: var(--colour-primary);">Key Contacts</h3>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-4);">
              <li style="display: flex; gap: var(--space-4); align-items: flex-start;">
                <div style="flex-shrink: 0; width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, var(--colour-primary), var(--colour-secondary)); display: flex; align-items: center; justify-content: center; color: var(--colour-white); font-weight: 700; font-size: 0.9375rem;">NH</div>
                <div>
                  <p style="font-weight: 600; color: var(--colour-primary); margin-bottom: 2px;">Nicola Holland</p>
                  <p style="font-size: 0.875rem; color: var(--colour-muted); margin-bottom: var(--space-1);">Managing Director</p>
                  <a href="mailto:nicola.holland@manchesterlmc.co.uk" style="font-size: 0.875rem; color: var(--colour-secondary);">nicola.holland@manchesterlmc.co.uk</a>
                </div>
              </li>
            </ul>
          </div>

        </div><!-- /left col -->

        <!-- Right: map -->
        <div>
          <div class="map-embed" aria-label="Map showing Manchester LMC office location at Oak House, 47 Graham Street, Beswick, Manchester M11 3BB">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2372.4!2d-2.1775!3d53.4765!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sOak+House%2C+47+Graham+Street%2C+Beswick%2C+Manchester+M11+3BB!5e0!3m2!1sen!2suk!4v1700000000000!5m2!1sen!2suk"
              title="Map showing Manchester LMC at Oak House, 47 Graham Street, Beswick, Manchester M11 3BB"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>

          <!-- Directions note -->
          <div style="margin-top: var(--space-4); padding: var(--space-4); background-color: var(--colour-neutral); border-radius: var(--radius-md);">
            <p style="font-size: 0.875rem; color: var(--colour-muted); margin: 0;">
              <strong style="color: var(--colour-primary);">Getting here:</strong> Oak House is on Graham Street in Beswick, accessible via Ashton New Road (A662). Metrolink: Beswick stop (Ashton-under-Lyne line), 5-minute walk. Free parking available on site.
            </p>
          </div>

          <div style="margin-top: var(--space-4);">
            <a
              href="https://www.google.com/maps/dir/?api=1&destination=Oak+House,+47+Graham+Street,+Beswick,+Manchester+M11+3BB"
              class="btn btn--outline"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Open directions to Manchester LMC in Google Maps (opens in new tab)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="3 11 22 2 13 21 11 13 3 11"/>
              </svg>
              Get Directions
            </a>
          </div>
        </div><!-- /right col -->

      </div><!-- /grid-2 -->
    </div>
  </section>

  <!-- ── Contact Form ────────────────────────────────────────── -->
  <section class="section section--alt" aria-labelledby="contact-form-heading">
    <div class="container">

      <div class="section-header section-header--center" style="margin-bottom: var(--space-10);">
        <h2 id="contact-form-heading">Send Us a Message</h2>
        <p>Use this form to send a general enquiry to the Manchester LMC team. We aim to respond within two working days.</p>
      </div>

      <form
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
        data-ajax
        novalidate
        aria-label="Contact form"
        style="max-width: 760px; margin: 0 auto; background-color: var(--colour-white); padding: var(--space-8); border-radius: var(--radius-xl); border: 1px solid var(--colour-border);">

        <div class="grid-2" style="gap: var(--space-5);">

          <!-- Name -->
          <div class="form-group">
            <label class="form-label" for="contact-name">
              Full Name <span class="required" aria-hidden="true">*</span>
            </label>
            <input
              class="form-input"
              type="text"
              id="contact-name"
              name="name"
              autocomplete="name"
              required
              aria-required="true"
              placeholder="Dr Jane Smith">
          </div>

          <!-- Practice Name -->
          <div class="form-group">
            <label class="form-label" for="contact-practice">
              Practice Name
            </label>
            <input
              class="form-input"
              type="text"
              id="contact-practice"
              name="practice_name"
              autocomplete="organization"
              placeholder="e.g. Ardwick Green Medical Practice">
          </div>

        </div><!-- /grid-2 -->

        <div class="grid-2" style="gap: var(--space-5);">

          <!-- Role -->
          <div class="form-group">
            <label class="form-label" for="contact-role">
              Your Role <span class="required" aria-hidden="true">*</span>
            </label>
            <select
              class="form-select"
              id="contact-role"
              name="role"
              required
              aria-required="true">
              <option value="" disabled selected>Select your role…</option>
              <option value="gp-partner">GP Partner</option>
              <option value="salaried-gp">Salaried GP</option>
              <option value="locum-gp">Locum GP</option>
              <option value="practice-manager">Practice Manager</option>
              <option value="nurse">Nurse</option>
              <option value="ahp">AHP</option>
              <option value="other">Other</option>
            </select>
          </div>

          <!-- Subject -->
          <div class="form-group">
            <label class="form-label" for="contact-subject">
              Subject <span class="required" aria-hidden="true">*</span>
            </label>
            <input
              class="form-input"
              type="text"
              id="contact-subject"
              name="subject"
              required
              aria-required="true"
              placeholder="e.g. Contract query">
          </div>

        </div><!-- /grid-2 -->

        <!-- Message -->
        <div class="form-group">
          <label class="form-label" for="contact-message">
            Message <span class="required" aria-hidden="true">*</span>
          </label>
          <textarea
            class="form-textarea"
            id="contact-message"
            name="message"
            rows="7"
            required
            aria-required="true"
            placeholder="Please describe your enquiry in as much detail as you'd like…"
            style="min-height: 160px;"></textarea>
          <p class="form-hint">Please do not include patient-identifiable information in this form.</p>
        </div>

        <!-- Privacy checkbox -->
        <div class="form-group" style="margin-bottom: var(--space-6);">
          <label style="display: flex; gap: var(--space-3); align-items: flex-start; cursor: pointer;">
            <input
              type="checkbox"
              name="privacy_agreed"
              id="contact-privacy"
              required
              aria-required="true"
              style="flex-shrink: 0; width: 18px; height: 18px; margin-top: 2px; accent-color: var(--colour-secondary); cursor: pointer;">
            <span style="font-size: 0.9rem; color: var(--colour-muted); line-height: 1.6;">
              I have read and agree to Manchester LMC's
              <a href="#" style="color: var(--colour-secondary);">Privacy Policy</a>.
              I understand my data will be used only to respond to my enquiry and stored securely in line with UK GDPR.
              <span class="required" aria-hidden="true"> *</span>
            </span>
          </label>
        </div>

        <!-- Hidden honeypot (spam prevention) -->
        <input type="text" name="_gotcha" style="display: none;" tabindex="-1" aria-hidden="true">
        <input type="hidden" name="_subject" value="New enquiry from manchesterlmc.co.uk">

        <!-- Submit -->
        <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--space-4);">
          <p style="font-size: 0.8125rem; color: var(--colour-muted); margin: 0;">
            Fields marked <span class="required" aria-hidden="true">*</span> are required.
          </p>
          <button type="submit" class="btn btn--primary btn--lg">
            Send Message
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>
        </div>

      </form>

    </div>
  </section>
