<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or site.name }}">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.name }}</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,600;0,9..144,700;1,9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- Styles -->
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="/assets/css/components.css">

  {% block head %}{% endblock %}
</head>
<body>

<a href="#main-content" class="skip-link">Skip to main content</a>

{% include "partials/nav.njk" %}

<!-- ── Main Content ────────────────────────────────────────── -->
<main id="main-content"{% if mainClass %} class="{{ mainClass }}"{% endif %}>

  {{ content | safe }}

  {% if showContactStrip %}{% include "partials/contact-strip.njk" %}{% endif %}

</main>

{% include "partials/footer.njk" %}

{% if showDisclaimer %}
<!-- Disclaimer Overlay -->
<div id="disclaimer-overlay" class="disclaimer-overlay" role="dialog" aria-modal="true" aria-labelledby="disclaimer-title">
  <div class="disclaimer-backdrop" id="disclaimer-backdrop" aria-hidden="true"></div>
  <div class="disclaimer-dialog">
    <div class="disclaimer-content">
      <button class="disclaimer-close" id="disclaimer-close" aria-label="Close disclaimer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
        </svg>
      </button>
      <h2 id="disclaimer-title">Website Under Development</h2>
      <div class="disclaimer-text">
        <p>This website is currently <strong>under development</strong> and is being made available for testing and feedback purposes.</p>
        <p>Please be aware that:</p>
        <ul class="disclaimer-list">
          <li>The content and information presented on this site may be <strong>subject to change</strong>.</li>
          <li>Some features and sections may be incomplete or contain placeholder data.</li>
          <li>The official Manchester LMC website at <a href="https://www.manchesterlmc.co.uk" target="_blank" rel="noopener noreferrer">manchesterlmc.co.uk</a> should be considered the authoritative source for information.</li>
        </ul>
        <div class="disclaimer-actions">
          <button class="btn btn--primary" id="accept-disclaimer">I Understand — Continue to Site</button>
          <button class="btn btn--outline" id="view-again-disclaimer">View Official Site Instead</button>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- End Disclaimer Overlay -->
{% endif %}

<script src="/assets/js/main.js"></script>

{% block scripts %}{% endblock %}

</body>
</html>
