---
layout: layouts/base.njk
mainClass: page-news-post
---

<article class="news-post">

  <header class="news-post-header">
    <div class="container">
      <div class="news-post-meta">
        <span class="badge {{ category | badgeClass }}">{{ category | categoryName }}</span>
        <time datetime="{{ date | dateISO }}" class="news-post-date">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {{ date | dateFull }}
        </time>
      </div>
      <h1 class="news-post-title">{{ title }}</h1>
      {% if excerpt %}
        <p class="news-post-excerpt">{{ excerpt }}</p>
      {% endif %}
    </div>
  </header>

  {% if image %}
  <div class="news-post-image">
    <div class="container">
      <img src="{{ image }}" alt="{{ imageAlt or title }}" loading="eager" decoding="async">
    </div>
  </div>
  {% endif %}

  <div class="news-post-body">
    <div class="container">
      <div class="news-post-content prose">
        {{ content | safe }}
      </div>
      <div class="news-post-footer">
        <a href="/news/" class="btn btn--outline news-post-back">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back to News
        </a>
      </div>
    </div>
  </div>

</article>
