<article class="news-card reveal{% if loop.index0 % 3 == 1 %} reveal-delay-1{% elif loop.index0 % 3 == 2 %} reveal-delay-2{% endif %}" data-category="{{ article.data.category }}" role="listitem">
  <div class="news-card-image">
    {% if article.data.image %}
      <img src="{{ article.data.image }}" alt="" loading="lazy">
    {% else %}
      <div class="news-card-image-placeholder" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
    {% endif %}
  </div>
  <div class="news-card-body">
    <div class="news-card-meta">
      <span class="badge {{ article.data.category | badgeClass }}">{{ article.data.category | categoryName }}</span>
      <span class="news-card-date">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <time datetime="{{ article.date | dateISO }}">{{ article.date | dateDisplay }}</time>
      </span>
    </div>
    <h3><a href="{{ article.url }}">{{ article.data.title }}</a></h3>
    <p class="news-card-excerpt">{{ article.data.excerpt }}</p>
    <a href="{{ article.url }}" class="news-card-readmore" aria-label="Read more about {{ article.data.title }}">
      Read more
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>
</article>
