  <!-- Post a vacancy -->
  <section class="section section--neutral" id="post" aria-labelledby="post-heading">
    <div class="container">
      <div style="max-width:780px;margin:0 auto">
        <div class="section-header" style="margin-bottom:var(--space-8)">
          <span class="section-eyebrow">Recruiting?</span>
          <h2 id="post-heading">Post a Vacancy</h2>
          <p>Listing a role on the Manchester LMC job board is free for member practices and £50 for non-members. Listings remain live for 4 weeks or until you request removal.</p>
        </div>

        <!-- Auth gate -->
        <div id="vacancy-auth-gate">
          <div class="login-gate">
            <div class="login-gate-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h3>Members Only</h3>
            <p>You must be logged in as a Manchester LMC subscriber to post a vacancy. If you are not yet a member, you can register for a free practice membership or a £100/year locum subscription.</p>
            <div class="login-gate-actions">
              <a href="/members/" class="btn btn--primary">Login to your account</a>
              <a href="/members/#register" class="btn btn--outline">Register as a member</a>
            </div>
          </div>
        </div>

        <!-- Vacancy form (shown when authenticated) -->
        <div id="vacancy-form" style="display:none">
          <form action="https://formspree.io/f/placeholder" method="POST" data-ajax novalidate aria-label="Post a vacancy form">

            <div class="form-group">
              <label class="form-label" for="job-title">Job Title <span class="required" aria-hidden="true">*</span></label>
              <input class="form-input" type="text" id="job-title" name="job_title" required placeholder="e.g. Salaried GP — 6 Sessions">
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-5)">
              <div class="form-group">
                <label class="form-label" for="practice-name">Practice Name <span class="required" aria-hidden="true">*</span></label>
                <input class="form-input" type="text" id="practice-name" name="practice_name" required>
              </div>
              <div class="form-group">
                <label class="form-label" for="job-location">Location / Postcode <span class="required" aria-hidden="true">*</span></label>
                <input class="form-input" type="text" id="job-location" name="location" required placeholder="e.g. Manchester M4">
              </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-5)">
              <div class="form-group">
                <label class="form-label" for="contract-type">Contract Type</label>
                <select class="form-select" id="contract-type" name="contract_type">
                  <option value="" disabled selected>Select type</option>
                  <option value="gp-partner">GP Partner</option>
                  <option value="salaried-gp">Salaried GP</option>
                  <option value="locum">Locum</option>
                  <option value="practice-manager">Practice Manager</option>
                  <option value="nurse">Nurse / AHP</option>
                  <option value="admin">Administrative</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label" for="closing-date">Closing Date</label>
                <input class="form-input" type="date" id="closing-date" name="closing_date">
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="job-description">Job Description <span class="required" aria-hidden="true">*</span></label>
              <textarea class="form-textarea" id="job-description" name="job_description" rows="6" required placeholder="Describe the role, hours, salary (if applicable), and how to apply."></textarea>
            </div>

            <div class="form-group">
              <label class="form-label" for="contact-email">Application Contact Email <span class="required" aria-hidden="true">*</span></label>
              <input class="form-input" type="email" id="contact-email" name="contact_email" required placeholder="Where should applications be sent?">
            </div>

            <button type="submit" class="btn btn--primary btn--lg">Submit Vacancy Listing</button>
          </form>
        </div>

      </div>
    </div>
  </section>
